# chuk-mcp-her environment variables
# Copy to .env and customise as needed

# ============================================================================
# Server
# ============================================================================

# Force stdio transport mode (set to any value)
# MCP_STDIO=1

# ============================================================================
# Cache Configuration
# ============================================================================

# HTTP response cache directory (default: ~/.cache/chuk-mcp-her)
# HER_CACHE_DIR=./cache

# Cache TTL per source (seconds)
# HER_NHLE_CACHE_TTL=86400     # NHLE: 24 hours (default)
# HER_AIM_CACHE_TTL=604800     # AIM: 7 days (default)
# HER_HG_CACHE_TTL=3600        # Heritage Gateway: 1 hour (default)

# ============================================================================
# Rate Limiting
# ============================================================================

# Maximum requests per second to ArcGIS services (default: 5)
# HER_RATE_LIMIT=5

# Request timeout in seconds (default: 30)
# HER_TIMEOUT=30
